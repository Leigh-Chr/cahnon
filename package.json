{
	"name": "cahnon",
	"version": "0.1.0",
	"description": "Write freely. Stay consistent. A desktop application for fiction writers.",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"knip": "knip",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:all": "vitest run && cargo test --manifest-path src-tauri/Cargo.toml",
		"test:e2e": "pnpm tauri build && wdio run ./wdio.conf.ts",
		"tauri": "tauri",
		"prepare": "husky",
		"dictionaries:download": "./scripts/download-dictionaries.sh"
	},
	"lint-staged": {
		"*.{ts,svelte,js}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,css,html,yaml}": [
			"prettier --write"
		]
	},
	"license": "GPL-3.0",
	"dependencies": {
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-dialog": "^2.6.0",
		"@tiptap/core": "^3.17.1",
		"@tiptap/extension-character-count": "^3.17.1",
		"@tiptap/extension-highlight": "^3.17.1",
		"@tiptap/extension-placeholder": "^3.17.1",
		"@tiptap/extension-typography": "^3.17.1",
		"@tiptap/pm": "^3.17.1",
		"@tiptap/starter-kit": "^3.17.1",
		"docx": "^9.5.1",
		"file-saver": "^2.0.5",
		"mammoth": "^1.11.0",
		"pdf-lib": "^1.17.1"
	},
	"pnpm": {
		"overrides": {
			"cookie": ">=0.7.0"
		}
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tauri-apps/cli": "^2",
		"@testing-library/svelte": "^5.3.1",
		"@types/file-saver": "^2.0.7",
		"@types/mocha": "^10.0.10",
		"@wdio/cli": "^9.23.2",
		"@wdio/globals": "^9.23.0",
		"@wdio/local-runner": "^9.23.2",
		"@wdio/mocha-framework": "^9.23.2",
		"@wdio/spec-reporter": "^9.23.2",
		"@wdio/types": "^9.23.2",
		"eslint": "^9.39.2",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"knip": "^5.82.1",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.48.2",
		"svelte-check": "^4.3.5",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
