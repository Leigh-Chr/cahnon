{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:window:allow-show",
		"core:window:allow-set-title",
		"core:window:allow-close",
		"opener:default",
		"dialog:default",
		"dialog:allow-open",
		"dialog:allow-save",
		"dialog:allow-message",
		"dialog:allow-ask",
		"dialog:allow-confirm",
		"fs:default",
		"fs:allow-read",
		"fs:allow-write",
		"fs:allow-exists",
		"fs:allow-mkdir",
		"fs:allow-remove",
		"fs:allow-rename",
		"fs:allow-copy-file",
		"window-state:default"
	]
}
